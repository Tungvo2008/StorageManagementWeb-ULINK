# Database
DATABASE_URL=sqlite:///./storage.db

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Company info (for invoice)
COMPANY_NAME=My Company
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=
COMPANY_TAX_CODE=
# Optional (PDF invoice): path to logo image (png/jpg)
COMPANY_LOGO_PATH=
# Optional (PDF invoice): Unicode font paths for Vietnamese (ttf/otf)
INVOICE_PDF_FONT_PATH=
INVOICE_PDF_FONT_BOLD_PATH=
# Optional (PDF invoice): payment lines, use | to separate lines
INVOICE_PAYMENT_LINES=

DEFAULT_CURRENCY=USD
DEFAULT_TAX_RATE=0

# Auth / JWT
# IMPORTANT: change JWT_SECRET_KEY in production
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Invoice numbering + Excel template export (optional)
INVOICE_PREFIX=UL
INVOICE_NUMBER_DIGITS=4
INVOICE_TEMPLATE_XLSM_PATH=/Users/thanhtungvo/ULINK INVOICE/Mau_Invoice.xlsm
